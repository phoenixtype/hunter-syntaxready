# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Payment Configuration
# ⚠️ NEVER put live keys in local files! Set these in Supabase secrets
# Paystack (Nigerian Payments) - Set in Supabase Dashboard
PAYSTACK_SECRET_KEY="your-paystack-secret-key"
VITE_PAYSTACK_PUBLIC_KEY="pk_test_your-paystack-public-key"

# Stripe (International Payments) - Set in Supabase Dashboard
STRIPE_SECRET_KEY="your-stripe-secret-key"
VITE_STRIPE_PUBLISHABLE_KEY="your-stripe-public-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# Stripe Recruiter Price IDs
VITE_STRIPE_RECRUITER_STARTER_PRICE_ID="price_xxx"
VITE_STRIPE_RECRUITER_GROWTH_PRICE_ID="price_xxx"

# AI & Scraper Keys
FIRECRAWL_API_KEY="your-firecrawl-api-key"
LOVABLE_API_KEY="your-lovable-api-key"
